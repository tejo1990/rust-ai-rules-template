# MCP Server 환경변수 설정
# cp .env.example .env 후 실제 값으로 변경

# ── 필수 ──────────────────────────────────────────────────────

# GitHub Personal Access Token
# 권한: repo, read:org
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# 작업 디렉터리 (이 repo의 상위 폴더 또는 프로젝트 루트)
# 예: WORKSPACE_ROOT=/Users/yourname/projects
WORKSPACE_ROOT=/path/to/your/projects

# ── 선택 (web-axum 도메인) ────────────────────────────────────

# PostgreSQL (로컬 dev DB)
POSTGRES_URL=postgresql://postgres:password@localhost:5432/dev

# ── AI API 키 (GitHub Actions 자동 업데이트용) ────────────────
# 이 값은 .env에 넣지 말고 GitHub Secrets에 설정하세요
# Settings > Secrets > Actions > New secret: ANTHROPIC_API_KEY
# ANTHROPIC_API_KEY=sk-ant-...

# ── MCP 서버 포트 (기본값 변경 시) ───────────────────────────
# MCP_GIT_PORT=3001
# MCP_GITHUB_PORT=3002
# MCP_FILESYSTEM_PORT=3003
# MCP_THINKING_PORT=3004
# MCP_MEMORY_PORT=3005
# MCP_FETCH_PORT=3006
# MCP_POSTGRES_PORT=3007
# MCP_CARGO_PORT=3008
