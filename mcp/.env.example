# MCP Docker Stack 환경변수
# cp .env.example .env → 편집 → docker compose up -d

# ── GitHub ──────────────────────────────────────────────────────────────────
# https://github.com/settings/tokens 에서 생성
# 필요 권한: repo, read:org
GITHUB_TOKEN=ghp_your_token_here

# ── 워크스페이스 ─────────────────────────────────────────────────────────────
# AI 에이전트가 접근할 수 있는 프로젝트 루트 디렉토리
# 보안: 이 경로 밖의 파일에는 에이전트가 접근 불가
PROJECTS_ROOT=~/projects

# ── 선택적 서비스 ─────────────────────────────────────────────────────────────
# Notion (문서 관리 MCP)
# NOTION_TOKEN=secret_your_notion_token

# Linear (이슈 트래킹 MCP)
# LINEAR_API_KEY=lin_api_your_key

# Slack (알림 MCP)
# SLACK_BOT_TOKEN=xoxb-your-token
